# =============================================================================
# LLM OSINT Pipeline - Dev Container Environment (Repo Root .env)
# =============================================================================
# This file is used when running services directly in the dev container
# (not inside Docker Compose containers)
# =============================================================================

# Copy this to .env and customize if needed
# This file is already in .gitignore

# Database (use service name when dev container is on docker_default network)
DATABASE_URL=postgresql://osint:osint@postgres:5432/osint

# MinIO Object Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=osint-raw

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=osint_chunks_qwen3_0_6b

# Neo4j Graph DB
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# Temporal
TEMPORAL_ADDRESS=temporal:7233

# Redis
REDIS_URL=redis://redis:6379

# Application Settings
NODE_ENV=development
LOG_LEVEL=info

# Location merge threshold (meters)
LOCATION_MERGE_THRESHOLD_METERS=1000

# OpenRouter (LLM)
# Set your key here to enable LLM planning in LangGraph
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
# Optional: default model (used as fallback)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: per-graph model overrides
OPENROUTER_PLANNER_MODEL=openai/gpt-4o-mini
OPENROUTER_WORKER_MODEL=openai/gpt-4o-mini
OPENROUTER_REPORT_MODEL=openai/gpt-4o-mini
OPENROUTER_REPORT_WORKER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
OPENROUTER_TIMEOUT_SECONDS=400
OPENROUTER_PLANNER_TIMEOUT_SECONDS=400
OPENROUTER_WORKER_TIMEOUT_SECONDS=400
OPENROUTER_REPORT_TIMEOUT_SECONDS=400
OPENROUTER_REPORT_WORKER_TIMEOUT_SECONDS=400
OPENROUTER_TITLE_TIMEOUT_SECONDS=400

# Embeddings: switch provider without code changes
# - openrouter: uses OpenRouter embeddings
# - vllm: local Docker vLLM or any remote vLLM/OpenAI-compatible endpoint
# - custom: any OpenAI-compatible HTTP endpoint you control
EMBEDDING_PROVIDER=vllm
EMBEDDING_API_URL=http://worker-embedding:8000/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_SERVED_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_TRUST_REMOTE_CODE=true
EMBEDDING_DTYPE=auto
EMBEDDING_TASK=embed
EMBEDDING_MAX_MODEL_LEN=
EMBEDDING_TENSOR_PARALLEL_SIZE=1
EMBEDDING_PIPELINE_PARALLEL_SIZE=1
EMBEDDING_GPU_MEMORY_UTILIZATION=0.9
EMBEDDING_ENFORCE_SINGLE_MODEL=true
EMBEDDING_VLLM_ARGS=
EMBEDDING_TIMEOUT_MS=180000
EMBEDDING_QUERY_TIMEOUT_MS=60000
EMBEDDING_TIMEOUT_SECONDS=180
EMBEDDING_MAX_ATTEMPTS=3
EMBEDDING_RETRY_DELAY_MS=750
# Optional fallback when primary embedding endpoint fails.
# Uses OPENROUTER_API_KEY + OPENROUTER_EMBED_MODEL.
EMBEDDING_FALLBACK_TO_OPENROUTER=false

# MCP Python Tool Bridge
PYTHON_BIN=python3
MCP_PYTHON_TOOLS='[]'
MCP_TOOLSET=default

# LangGraph MCP routing
MCP_SERVER_URL=http://mcp-server:3001/mcp
MCP_SERVER_KALI_URL=http://mcp-server-kali:3002/mcp
# LangGraph run launcher (used by apps/api on POST /runs)
LANGGRAPH_AUTOSTART=true
LANGGRAPH_PYTHON_BIN=python3
# Optional explicit path if auto-detection fails:
# LANGGRAPH_SCRIPT_PATH=/workspaces/llm-osint/services/agent-langgraph/src/run_planner.py
LANGGRAPH_MAX_ITERATIONS=15
LANGGRAPH_MAX_WORKER=5
STAGE1_MAX_TOOLS_PER_ITERATION=5
STAGE1_BLUEPRINT_ENABLED=true
STAGE1_BLUEPRINT_CONTRACT_PATH=/workspaces/llm-osint/schemas/stage1_graph_blueprint_contract.v1.json
STAGE1_BLUEPRINT_ENFORCEMENT=balanced
STAGE1_SOCIAL_TIMELINE_MAX_FAILURES=2
# Optional override JSON:
# MCP_TOOL_SERVER_MAP='{"fetch_url":"normal","osint_sherlock_username":"kali"}'

# Social Platform Credentials (optional, for Python tools)
X_BEARER_TOKEN=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
HIBP_API_KEY=
SHODAN_API_KEY=

# MCP Test Helpers (optional)
X_TEST_USERNAME=

# X (Twitter) API Credentials
# Get your credentials from https://developer.x.com/

# Required for API approach (get_user_posts.py)
X_BEARER_TOKEN=your_bearer_token_here
X_TEST_USERNAME=your_test_username

# Browserbase Credentials
# Get your credentials from https://browserbase.com/

# Required for Browserbase approach
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# Tavily Credentials
# Shared fallback key plus optional per-endpoint overrides
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_API_KEY=
TAVILY_RESEARCH_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_RESEARCH_API_URL=https://api.tavily.com/research

# LinkedIn Credentials
# Required for LinkedIn scraping (get_linkedin_posts_browserbase.py)
LINKEDIN_EMAIL=your_linkedin_email_here
LINKEDIN_PASSWORD=your_linkedin_password_here

# MCP Python tool bridge
PYTHON_BIN=python3
MCP_PYTHON_TOOLS='[]'
# Example:
# MCP_PYTHON_TOOLS='[{"name":"x_get_user_posts","description":"Fetch X posts via API","scriptPath":"apps/mcp-server/src/tools/tools_python/get_user_posts.py","timeoutMs":30000}]'
# Unified wrapper example:
# MCP_PYTHON_TOOLS='[{"name":"person_search","description":"Search web pages about a person","scriptPath":"apps/mcp-server/src/tools/tools_python/unified_research_mcp.py","timeoutMs":120000},{"name":"x_get_user_posts_api","description":"Fetch X posts via official API v2 (research integration)","scriptPath":"apps/mcp-server/src/tools/tools_python/unified_research_mcp.py","timeoutMs":180000},{"name":"linkedin_download_html_ocr","description":"Download LinkedIn profile/activity HTML via Browserbase (research integration)","scriptPath":"apps/mcp-server/src/tools/tools_python/unified_research_mcp.py","timeoutMs":300000},{"name":"google_serp_person_search","description":"Search person via Google SERP service and archive HTML results (research integration)","scriptPath":"apps/mcp-server/src/tools/tools_python/unified_research_mcp.py","timeoutMs":180000},{"name":"arxiv_search_and_download","description":"Search arXiv and download papers (research integration)","scriptPath":"apps/mcp-server/src/tools/tools_python/unified_research_mcp.py","timeoutMs":300000}]'
