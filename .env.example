# =============================================================================
# LLM OSINT Pipeline - Dev Container Environment (Repo Root .env)
# =============================================================================
# This file is used when running services directly in the dev container
# (not inside Docker Compose containers)
# =============================================================================

# Copy this to .env and customize if needed
# This file is already in .gitignore

# Database (use service name when dev container is on docker_default network)
DATABASE_URL=postgresql://osint:osint@postgres:5432/osint

# MinIO Object Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=osint-raw

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=osint_chunks

# Neo4j Graph DB
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# Temporal
TEMPORAL_ADDRESS=temporal:7233

# Redis
REDIS_URL=redis://redis:6379

# Application Settings
NODE_ENV=development
LOG_LEVEL=info

# Location merge threshold (meters)
LOCATION_MERGE_THRESHOLD_METERS=1000

# OpenRouter (LLM)
# Set your key here to enable LLM planning in LangGraph
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
# Optional: default model (used as fallback)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: per-graph model overrides
OPENROUTER_PLANNER_MODEL=openai/gpt-4o-mini
OPENROUTER_WORKER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small

# MCP Python Tool Bridge
PYTHON_BIN=python3
MCP_PYTHON_TOOLS='[]'

# Social Platform Credentials (optional, for Python tools)
X_BEARER_TOKEN=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# MCP Test Helpers (optional)
X_TEST_USERNAME=
