# =============================================================================
# LLM OSINT Pipeline - macOS Host Configuration
# =============================================================================
# Use this configuration when running services on a macOS host machine.
# 
# Setup: cp .env.macos .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use 'localhost' when accessing from macOS host
# Services expose ports to host via docker-compose port mappings
DATABASE_URL=postgresql://osint:osint@localhost:5432/osint
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=osint
DATABASE_USER=osint
DATABASE_PASSWORD=osint

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
# Access via localhost since ports are exposed to host
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=osint-raw

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=osint_chunks

# -----------------------------------------------------------------------------
# Graph Database (Neo4j)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# -----------------------------------------------------------------------------
# Temporal Workflow Engine
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
MCP_PORT=3001
WEB_PORT=5173

# -----------------------------------------------------------------------------
# Notes for macOS Host
# -----------------------------------------------------------------------------
# 1. Requires Docker Desktop for Mac
#
# 2. Start Docker services:
#    docker compose -f infra/docker/docker-compose.yml up -d
#
# 3. All services are accessed via localhost with exposed ports
#
# 4. On Apple Silicon (M1/M2/M3), ensure Docker Desktop uses:
#    - "Use Rosetta for x86/amd64 emulation" if needed
#    - "VirtioFS" for better file sharing performance
#
# 5. If localhost doesn't work, try:
#    - 127.0.0.1 instead of localhost
#    - host.docker.internal for host machine access
#
# 6. Performance tip: Use Docker volumes instead of bind mounts
#    for better I/O performance on macOS
