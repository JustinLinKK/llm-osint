# X (Twitter) API Credentials
# Get your credentials from https://developer.x.com/

# Required for API approach (get_user_posts.py)
X_BEARER_TOKEN=your_bearer_token_here
X_TEST_USERNAME=your_test_username

# Browserbase Credentials
# Get your credentials from https://browserbase.com/

# Required for Browserbase approach
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# LinkedIn Credentials
# Required for LinkedIn scraping (get_linkedin_posts_browserbase.py)
LINKEDIN_EMAIL=your_linkedin_email_here
LINKEDIN_PASSWORD=your_linkedin_password_here

# MCP Python tool bridge
PYTHON_BIN=python3
MCP_PYTHON_TOOLS='[]'
# Example:
# MCP_PYTHON_TOOLS='[{"name":"x_get_user_posts","description":"Fetch X posts via API","scriptPath":"apps/mcp-server/src/tools/tools_python/get_user_posts.py","timeoutMs":30000}]'
