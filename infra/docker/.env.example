# =============================================================================
# LLM OSINT Pipeline - Docker Compose .env (Optional)
# =============================================================================
# This file is only used when you run docker compose from infra/docker.
# If you run docker compose from the repo root, it will use the root .env instead.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use service names when running from dev container on docker_default network
# Use localhost when running from host machine
DATABASE_URL=postgresql://osint:osint@postgres:5432/osint
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=osint
DATABASE_USER=osint
DATABASE_PASSWORD=osint

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
# Use 'minio' service name when running from dev container on docker_default network
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=osint-raw

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=osint_chunks_qwen3_0_6b

# -----------------------------------------------------------------------------
# Graph Database (Neo4j)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# -----------------------------------------------------------------------------
# Temporal Workflow Engine
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=temporal:7233

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Application Ports
# -----------------------------------------------------------------------------
API_PORT=3000
MCP_PORT=3001
WEB_PORT=5173

# -----------------------------------------------------------------------------
# OpenRouter (LLM)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_PLANNER_MODEL=openai/gpt-4o-mini
OPENROUTER_WORKER_MODEL=openai/gpt-4o-mini
EMBEDDING_PROVIDER=vllm
EMBEDDING_API_URL=http://worker-embedding:8000/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_SERVED_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_TRUST_REMOTE_CODE=true
EMBEDDING_DTYPE=auto
EMBEDDING_TASK=embed
EMBEDDING_MAX_MODEL_LEN=
EMBEDDING_TENSOR_PARALLEL_SIZE=1
EMBEDDING_PIPELINE_PARALLEL_SIZE=1
EMBEDDING_GPU_MEMORY_UTILIZATION=0.9
EMBEDDING_ENFORCE_SINGLE_MODEL=true
EMBEDDING_VLLM_ARGS=

# -----------------------------------------------------------------------------
# MCP Python Tool Bridge (optional)
# -----------------------------------------------------------------------------
PYTHON_BIN=python3
MCP_TOOLSET=default
MCP_PYTHON_TOOLS=[]
X_BEARER_TOKEN=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
X_TEST_USERNAME=
HIBP_API_KEY=
SHODAN_API_KEY=

TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_API_KEY=
TAVILY_RESEARCH_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_RESEARCH_API_URL=https://api.tavily.com/research



# LangGraph MCP routing
MCP_SERVER_URL=http://mcp-server:3001/mcp
MCP_SERVER_KALI_URL=http://mcp-server-kali:3002/mcp
LANGGRAPH_AUTOSTART=true
LANGGRAPH_MAX_ITERATIONS=3
STAGE1_MAX_TOOLS_PER_ITERATION=5
# Optional override JSON
# MCP_TOOL_SERVER_MAP={"fetch_url":"normal","osint_sherlock_username":"kali"}

# -----------------------------------------------------------------------------
# Docker Network
# -----------------------------------------------------------------------------
NET=docker_default
