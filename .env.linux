# =============================================================================
# LLM OSINT Pipeline - Native Linux Host Configuration
# =============================================================================
# Use this configuration when running services OUTSIDE of a dev container
# on a native Linux host machine.
# 
# Setup: cp .env.linux .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use 'localhost' when accessing from host machine (not inside dev container)
# Services expose ports to host via docker-compose port mappings
DATABASE_URL=postgresql://osint:osint@localhost:5432/osint
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=osint
DATABASE_USER=osint
DATABASE_PASSWORD=osint

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
# Access via localhost since ports are exposed to host
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=osint-raw

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=osint_chunks

# -----------------------------------------------------------------------------
# Graph Database (Neo4j)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# -----------------------------------------------------------------------------
# Temporal Workflow Engine
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
MCP_PORT=3001
WEB_PORT=5173

# -----------------------------------------------------------------------------
# Notes for Linux Host
# -----------------------------------------------------------------------------
# 1. Docker services must be running:
#    docker compose -f infra/docker/docker-compose.yml up -d
#
# 2. No need to connect to docker_default network (you're on the host)
#
# 3. All services are accessed via localhost with exposed ports
#
# 4. Firewall: Ensure ports 5432, 9000, 6333, 7687, 7233, 6379 are not blocked
