# =============================================================================
# LLM OSINT Pipeline - Native Linux Host Configuration (Deprecated)
# =============================================================================
# Deprecated: prefer copying .env.example to .env and update service hosts to
# localhost when running on a native Linux host.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use 'localhost' when accessing from host machine (not inside dev container)
# Services expose ports to host via docker-compose port mappings
DATABASE_URL=postgresql://osint:osint@localhost:5432/osint
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=osint
DATABASE_USER=osint
DATABASE_PASSWORD=osint

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
# Access via localhost since ports are exposed to host
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=osint-raw

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=osint_chunks

# -----------------------------------------------------------------------------
# Graph Database (Neo4j)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# -----------------------------------------------------------------------------
# Temporal Workflow Engine
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
MCP_PORT=3001
WEB_PORT=5173

# MCP Python Tool Bridge
PYTHON_BIN=python3
MCP_PYTHON_TOOLS='[]'

# Social Platform Credentials (optional, for Python tools)
X_BEARER_TOKEN=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# MCP Test Helpers (optional)
X_TEST_USERNAME=

# OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_PLANNER_MODEL=openai/gpt-4o-mini
OPENROUTER_WORKER_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# Notes for Linux Host
# -----------------------------------------------------------------------------
# 1. Docker services must be running:
#    docker compose -f infra/docker/docker-compose.yml up -d
#
# 2. No need to connect to docker_default network (you're on the host)
#
# 3. All services are accessed via localhost with exposed ports
#
# 4. Firewall: Ensure ports 5432, 9000, 6333, 7687, 7233, 6379 are not blocked
